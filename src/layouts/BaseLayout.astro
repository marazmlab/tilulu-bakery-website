---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Tilulu Bakery" } = Astro.props;

const currentPath = Astro.url.pathname;

function linkClass(href: string) {
  const isActive =
    href === "/" ? currentPath === "/" : currentPath.startsWith(href);
  return isActive
    ? "font-medium text-foreground"
    : "text-muted-foreground transition-colors hover:text-foreground";
}

---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <header class="border-b border-border">
      <nav
        class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4"
        aria-label="Główne menu"
      >
        <a href="/" class="text-lg font-semibold"> Piekarnia Tilulu </a>
        <ul class="flex gap-4 text-sm">
          <li>
            <a href="/oferta" class={linkClass("/oferta")}>Oferta</a>
          </li>
          <li>
            <a href="/o-nas" class={linkClass("/o-nas")}>O nas</a>
          </li>
          <li>
            <a href="/zamowienia" class={linkClass("/zamowienia")}>Zamówienia</a>
          </li>
          <li>
            <a href="/kontakt" class={linkClass("/kontakt")}>Kontakt</a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>

    <footer class="mt-auto border-t border-border py-8">
      <div class="mx-auto max-w-5xl px-4 text-center text-sm text-muted-foreground">
        <p class="font-medium text-foreground">Piekarnia Tilulu · Szczecin</p>
        <p class="mt-1">Zapytania ofertowe - odpowiadamy w ciągu 24 godzin.</p>
        <p class="mt-1">
          © {new Date().getFullYear()} Tilulu Bakery. Wszelkie prawa zastrzeżone.
        </p>
      </div>
    </footer>
  </body>
</html>

