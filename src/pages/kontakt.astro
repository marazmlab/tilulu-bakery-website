---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt - Piekarnia Tilulu">
  <h1 class="text-3xl font-bold tracking-tight">Kontakt</h1>

  <p class="mt-4 max-w-2xl text-muted-foreground">
    Masz pytanie poza formularzem? Skontaktuj się bezpośrednio — dane
    kontaktowe uzupełnimy po uzgodnieniu z właścicielką.
  </p>

  <dl class="mt-8 max-w-md space-y-4">
    <div>
      <dt class="text-sm font-medium text-muted-foreground">E-mail</dt>
      <dd class="mt-1">kontakt@tilulu.pl (placeholder)</dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-muted-foreground">Telefon</dt>
      <dd class="mt-1">+48 — — — — — — (placeholder)</dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-muted-foreground">Lokalizacja</dt>
      <dd class="mt-1">Szczecin</dd>
    </div>
  </dl>

  <p class="mt-8">
    <a href="/zamowienia" class="font-medium text-primary hover:underline">
      Wolisz formularz? Wyślij zapytanie o zamówienie
    </a>
  </p>

</BaseLayout>
