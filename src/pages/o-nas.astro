---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="O nas - Piekarnia Tilulu">
  <h1 class="text-3xl font-bold tracking-tight">O nas</h1>

  <p class="mt-4 max-w-2xl text-muted-foreground">
    Tilulu to domowa piekarnia w Szczecinie. Łączymy argentyńskie inspiracje
    z rzemieślniczym podejściem do każdego zamówienia.
  </p>

  <div class="mt-8 flex aspect-video max-w-xl items-center justify-center rounded-xl border border-dashed bg-muted/40 text-sm text-muted-foreground">
    zdjęcie właścicielki - placeholder
  </div>

  <p class="mt-6 max-w-2xl text-muted-foreground">
    Pełna historia piekarni, wartości i linki do social mediów dodamy w
    kolejnej fazie projektu.
  </p>

</BaseLayout>
