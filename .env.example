# =============================================================================
# Tilulu Bakery — environment variables (template)
# Copy to .env and fill in real values.
# =============================================================================

# --- Supabase (server-only — Astro API routes) ---
# Dashboard: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (server-only — confirmation emails) ---
# Dashboard: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=shop@your-domain.com
OWNER_EMAIL=owner@example.com

# --- Application (server — links in emails, redirects) ---
SITE_URL=http://localhost:4321

# --- Analytics (client — load only after cookie consent) ---
# Astro requires the PUBLIC_ prefix for browser-accessible variables
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# =============================================================================
# Phase 2 — uncomment when you add SMS (SMSAPI.pl)
# =============================================================================
# SMSAPI_TOKEN=your-smsapi-token
# SMSAPI_SENDER_NAME=Tilulu
# OWNER_PHONE=+48123456789